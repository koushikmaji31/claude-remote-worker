#!/bin/bash
# Launch a Claude session that receives chat-bus messages HANDS-FREE:
# no typing "continue", no idle spinner. Runs claude inside tmux with a
# watcher that auto-types a nudge into the session whenever messages queue.
#
# Usage:  ./bus-claude [name]        e.g.  ./bus-claude backend
#         (no name -> auto agent-a/b/c...)
#
# The nudge triggers the UserPromptSubmit hook, which injects the pending
# messages — so the watcher itself never consumes anything.

set -u
DIR="$(cd "$(dirname "$0")" && pwd)"
. "$DIR/hooks/bus_env.sh" 2>/dev/null || BUS_URL=${CLAUDE_BUS_URL:-http://127.0.0.1:8899}

NAME=${1:-}
if [ -z "$NAME" ]; then
  taken=$(curl -s -m 3 ${BUS_AUTH[@]:-} "$BUS_URL/who" 2>/dev/null)
  NAME=agent-f
  for c in agent-a agent-b agent-c agent-d agent-e; do
    case "$taken" in *"\"$c\""*) ;; *) NAME=$c; break ;; esac
  done
fi
SESSION="bus-$NAME"

if tmux has-session -t "$SESSION" 2>/dev/null; then
  exec tmux attach -t "$SESSION"
fi

# Watcher: nudge the tmux session when messages are pending for NAME.
# Never consumes messages (reads pending counts from /who only).
nohup bash -c '
  DIR="'"$DIR"'"; NAME="'"$NAME"'"; SESSION="'"$SESSION"'"
  . "$DIR/hooks/bus_env.sh" 2>/dev/null || BUS_URL=${CLAUDE_BUS_URL:-http://127.0.0.1:8899}
  while tmux has-session -t "$SESSION" 2>/dev/null; do
    [ -f /tmp/claude-bus/off ] && { sleep 10; continue; }
    pending=$(curl -s -m 5 ${BUS_AUTH[@]:-} "$BUS_URL/who" | python3 -c "
import sys, json
try: print(json.load(sys.stdin).get(\"pending\", {}).get(\"$NAME\", 0))
except Exception: print(0)")
    if [ "${pending:-0}" -gt 0 ] 2>/dev/null; then
      tmux send-keys -t "$SESSION" "New chat-bus messages arrived — read and handle them." Enter
      # give the session time to consume before nudging again
      for i in $(seq 1 20); do
        sleep 3
        p=$(curl -s -m 5 ${BUS_AUTH[@]:-} "$BUS_URL/who" | python3 -c "
import sys, json
try: print(json.load(sys.stdin).get(\"pending\", {}).get(\"$NAME\", 0))
except Exception: print(0)")
        [ "${p:-0}" -eq 0 ] 2>/dev/null && break
      done
    fi
    sleep 4
  done
' >/tmp/claude-bus/watcher-$NAME.log 2>&1 &

CLAUDE_BUS_NAME=$NAME tmux new-session -s "$SESSION" -c "$DIR" \
  "CLAUDE_BUS_NAME=$NAME claude; tmux kill-session -t $SESSION 2>/dev/null"
